# ═══════════════════════════════════════════════════════════
# AURA — .gitignore raiz
# Turborepo + pnpm workspaces + TypeScript + Python
# ═══════════════════════════════════════════════════════════

# ── Dependências ──────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Build outputs ─────────────────────────────────────────
dist/
build/
out/
.next/
.expo/
.expo-shared/

# ── Turborepo cache ───────────────────────────────────────
.turbo/

# ── TypeScript ────────────────────────────────────────────
*.tsbuildinfo

# ── Testes e coverage ─────────────────────────────────────
coverage/
.nyc_output/
test-results/

# ── Variáveis de ambiente ─────────────────────────────────
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
!.env.example

# ── Logs ──────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
pnpm-debug.log*

# ── Sistema operacional ───────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDEs ──────────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# ── Python (apps/ia-service) ──────────────────────────────
__pycache__/
*.pyc
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# ── Infraestrutura local ──────────────────────────────────
minio-data/
ollama-data/
*.gguf
*.bin
.docker/

# ── React Native / Expo ───────────────────────────────────
*.jks
*.p8
*.p12
*.key
*.mobileprovision
android/
ios/
web-build/

# ── Drizzle ───────────────────────────────────────────────
drizzle/meta/